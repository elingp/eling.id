{
	"name": "eling.id",
	"version": "6.11.0",
	"private": true,
	"description": "Personal website of Eling Pramuatmaja",
	"keywords": [
		"blog",
		"personal-website",
		"astro",
		"tailwindcss",
		"astrojs"
	],
	"homepage": "https://eling.id/",
	"bugs": {
		"url": "https://github.com/elingp/eling.id/issues"
	},
	"license": "MIT",
	"author": "Eling Pramuatmaja <eling@eling.id> (https://eling.id/)",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/elingp/eling.id.git"
	},
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"postinstall": "simple-git-hooks",
		"dev": "astro dev",
		"build": "PUBLIC_COMMIT_HASH=$(git rev-parse HEAD 2>/dev/null || echo 'dev') astro build",
		"postbuild": "pagefind --site dist",
		"preview": "astro preview",
		"check": "astro check && biome check --no-errors-on-unmatched && prettier --check '**/*.{astro,css,md,mdx,yml,yaml}'",
		"check:ci": "astro check && biome ci --no-errors-on-unmatched && prettier --check '**/*.{astro,css,md,mdx,yml,yaml}'",
		"fix": "biome check --write --no-errors-on-unmatched && prettier --write --cache '**/*.{astro,css,md,mdx,yml,yaml}'"
	},
	"dependencies": {
		"@astrojs/markdown-remark": "^6.3.11",
		"@astrojs/mdx": "^4.3.14",
		"@astrojs/rss": "^4.0.18",
		"@astrojs/sitemap": "^3.7.2",
		"@fontsource/source-code-pro": "^5.2.7",
		"@fontsource/source-sans-3": "^5.2.9",
		"@fontsource/source-serif-4": "^5.2.9",
		"@tailwindcss/vite": "^4.2.4",
		"astro": "^5.18.1",
		"astro-embed": "^0.13.0",
		"astro-expressive-code": "^0.42.0",
		"astro-icon": "^1.1.5",
		"astro-robots-txt": "^1.0.0",
		"astro-webmanifest": "^1.0.0",
		"hastscript": "^9.0.1",
		"mdast-util-directive": "^3.1.0",
		"mdast-util-to-markdown": "^2.1.2",
		"mdast-util-to-string": "^4.0.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-external-links": "^3.0.0",
		"rehype-unwrap-images": "^1.0.0",
		"remark-directive": "^4.0.0",
		"satori": "^0.26.0",
		"satori-html": "^0.3.2",
		"sharp": "^0.34.5",
		"ultrahtml": "^1.6.0",
		"unified": "^11.0.5",
		"unist-util-visit": "^5.1.0"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@biomejs/biome": "2.4.14",
		"@iconify-json/fa7-brands": "^1.2.2",
		"@iconify-json/fa7-regular": "^1.2.3",
		"@iconify-json/fa7-solid": "^1.2.4",
		"@pagefind/default-ui": "^1.5.2",
		"@resvg/resvg-js": "^2.6.2",
		"@tailwindcss/typography": "^0.5.19",
		"@types/hast": "^3.0.4",
		"@types/mdast": "^4.0.4",
		"astro-grab": "^0.3.0",
		"astro-html-minifier-next": "^3.0.0",
		"astro-meta-tags": "^0.4.1",
		"astro-og": "^0.3.2",
		"autoprefixer": "^10.5.0",
		"lint-staged": "^16.4.0",
		"pagefind": "^1.5.2",
		"prettier": "3.8.3",
		"prettier-plugin-astro": "0.14.1",
		"prettier-plugin-tailwindcss": "0.8.0",
		"reading-time": "^1.5.0",
		"simple-git-hooks": "^2.13.1",
		"sonda": "^0.11.1",
		"tailwindcss": "^4.2.4",
		"typescript": "^5.9.3"
	},
	"engines": {
		"node": ">=24.0.0",
		"pnpm": ">=10.0.0"
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm lint-staged"
	},
	"lint-staged": {
		"*.{astro,js,jsx,ts,tsx,json,jsonc,html}": [
			"biome check --write --no-errors-on-unmatched"
		],
		"*.{astro,css,md,mdx,yml,yaml}": [
			"prettier --write --cache"
		]
	},
	"packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
