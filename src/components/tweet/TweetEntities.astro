---
import type { Entity } from "./api.ts";
import { renderHtmlWithBreaks } from "./api.ts";
import TweetLink from "./TweetLink.astro";

interface Props {
	entities: Entity[];
}

const { entities } = Astro.props;
---

{
	entities.map((item) => {
		switch (item.type) {
			case "hashtag":
			case "mention":
			case "url":
			case "symbol":
				return (
					<TweetLink href={item.href}>
						<span set:html={renderHtmlWithBreaks(item.text)} />
					</TweetLink>
				);
			case "media":
				return null;
			default:
				return <span set:html={renderHtmlWithBreaks(item.text)} />;
		}
	})
}
