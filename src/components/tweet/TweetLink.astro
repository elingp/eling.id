---
interface Props {
	href: string;
	className?: string;
}

const { href, className } = Astro.props;
// Slots must contain pre-sanitized content (see TweetEntities, TweetCommunityNote).
---

<a {href} class:list={["tweet-link", className]} target="_blank" rel="noopener noreferrer nofollow"
	><Fragment set:html={(await Astro.slots.render("default"))?.trim() ?? ""} /></a
>
