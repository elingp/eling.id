---
interface Props {
	href: string;
	className?: string;
	ariaLabel?: string;
}

const { href, className, ariaLabel } = Astro.props;
// Slots must contain pre-sanitized content (see TweetEntities, TweetCommunityNote).
---

<a
	{href}
	class:list={["tweet-link", className]}
	target="_blank"
	rel="noopener noreferrer nofollow"
	aria-label={ariaLabel}
	><Fragment set:html={(await Astro.slots.render("default"))?.trim() ?? ""} /></a
>
